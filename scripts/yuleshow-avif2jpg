#!/usr/bin/env python3
"""yuleshow-avif2jpg: convert a single .avif image to .jpg.

Usage: yuleshow-avif2jpg <input.avif>
"""

import sys
from pathlib import Path

from PIL import Image
import pillow_avif  # noqa: F401  (registers AVIF opener)


def log(msg):  print(f"🚀 {msg}")
def ok(msg):   print(f"✅ {msg}")
def err(msg):  print(f"❌ {msg}", file=sys.stderr)


def avif_to_jpg(input_path: Path) -> int:
    if not input_path.exists():
        err(f"File not found: {input_path}")
        return 1
    if input_path.suffix.lower() != ".avif":
        err("Input must be a .avif file.")
        return 1

    output_path = input_path.with_suffix(".jpg")
    log(f"Converting {input_path.name} -> {output_path.name}")
    with Image.open(input_path) as img:
        img.convert("RGB").save(output_path, "JPEG", quality=95)
    ok(f"Saved: {output_path}")
    return 0


if __name__ == "__main__":
    if len(sys.argv) != 2:
        err("Usage: yuleshow-avif2jpg <input.avif>")
        sys.exit(1)
    sys.exit(avif_to_jpg(Path(sys.argv[1])))
