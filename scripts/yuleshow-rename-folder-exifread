#!/usr/bin/env python3
"""yuleshow-rename-folder-exifread: rename + folder images via exifread.

Usage: yuleshow-rename-folder-exifread
Format: YYYYMMDD/YYYYMMDD_HHMMSS-<make>-<model>[_NNN].jpg
"""

import os
import shutil
import sys

import exifread


def log(msg):  print(f"🚀 {msg}")
def ok(msg):   print(f"✅ {msg}")
def warn(msg): print(f"⚠️  {msg}", file=sys.stderr)
def err(msg):  print(f"❌ {msg}", file=sys.stderr)


IMAGE_EXTS = (".png", ".jpg", ".jpeg")


def main(directory: str) -> int:
    log(f"Renaming + foldering images in: {directory}")
    counter_map: dict[str, int] = {}
    ok_n = skip_n = 0

    for fn in os.listdir(directory):
        if not fn.lower().endswith(IMAGE_EXTS):
            continue
        src = os.path.join(directory, fn)
        try:
            with open(src, "rb") as f:
                tags = exifread.process_file(f)
            dto = str(tags.get("EXIF DateTimeOriginal", "")).replace(":", "").replace(" ", "_")
            make = str(tags.get("Image Make", "")).replace(" ", "")
            model = str(tags.get("Image Model", "")).replace(" ", "")

            if not (dto and make and model):
                warn(f"Skip {fn}: missing EXIF")
                skip_n += 1
                continue

            date_folder = dto.split("_")[0]
            target_dir = os.path.join(directory, date_folder)
            os.makedirs(target_dir, exist_ok=True)

            base = f"{dto}-{make}-{model}"
            n = counter_map.get(base, 0)
            counter_map[base] = n + 1
            new_name = f"{base}.jpg" if n == 0 else f"{base}_{n:03d}.jpg"
            dst = os.path.join(target_dir, new_name)

            shutil.move(src, dst)
            ok(f"{fn} -> {os.path.relpath(dst, directory)}")
            ok_n += 1
        except Exception as e:
            err(f"{fn}: {e}")
            skip_n += 1

    log(f"Done. moved={ok_n} skipped={skip_n}")
    return 0


if __name__ == "__main__":
    sys.exit(main(os.getcwd()))
