#!/usr/bin/env python3
"""yuleshow-rename: rename JPGs in CWD by EXIF date + camera (Pillow).

Usage: yuleshow-rename
Format: YYYYMMDD_HHMMSS[-NNN]-<make>-<model>.JPG
Strips leading "JK-Imaging,-Ltd.-" from the camera prefix.
"""

import os
import re
import sys
from datetime import datetime

from PIL import Image


def log(msg):  print(f"🚀 {msg}")
def ok(msg):   print(f"✅ {msg}")
def warn(msg): print(f"⚠️  {msg}", file=sys.stderr)


IMAGE_EXTS = (".jpg", ".jpeg")


def clean(text: str) -> str:
    return re.sub(r"\s+", "-", text.strip())


def get_exif(path: str) -> dict:
    try:
        with Image.open(path) as img:
            return img._getexif() or {}
    except Exception:
        return {}


def format_name(date: datetime, make: str, model: str, ext: str, counter=None) -> str:
    date_str = date.strftime("%Y%m%d_%H%M%S")
    camera = f"{clean(make)}-{clean(model)}"
    camera = re.sub(r"^JK-Imaging,-Ltd\.-", "", camera)
    counter_str = f"-{counter:03d}" if counter is not None else ""
    return f"{date_str}{counter_str}-{camera}.{ext.upper()}"


def main() -> int:
    log(f"Renaming images in: {os.getcwd()}")
    seen = {}
    for fn in os.listdir("."):
        if not fn.lower().endswith(IMAGE_EXTS):
            continue

        exif = get_exif(fn)
        date_str = exif.get(36867)
        if not date_str:
            warn(f"Skip {fn}: no DateTimeOriginal")
            continue
        try:
            dt = datetime.strptime(date_str, "%Y:%m:%d %H:%M:%S")
        except Exception:
            warn(f"Bad date {date_str} in {fn}")
            continue

        make = exif.get(271, "Unknown")
        model = exif.get(272, "Camera")
        ext = os.path.splitext(fn)[1][1:]

        base = format_name(dt, make, model, ext)
        count = seen.get(base, 0)
        new_name = format_name(dt, make, model, ext, count if count > 0 else None)
        seen[base] = count + 1

        os.rename(fn, new_name)
        ok(f"{fn} -> {new_name}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
