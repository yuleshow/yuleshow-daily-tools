#!/usr/bin/env python3
"""yuleshow-pdf2jpg: convert PDF pages to JPG images (300 DPI).

Usage: yuleshow-pdf2jpg <input.pdf>
Output: <input>_page1.jpg, <input>_page2.jpg, ...
"""

import sys
from pathlib import Path

from pdf2image import convert_from_path


def log(msg):  print(f"🚀 {msg}")
def ok(msg):   print(f"✅ {msg}")
def err(msg):  print(f"❌ {msg}", file=sys.stderr)


def pdf_to_jpg(pdf_path: Path) -> int:
    if not pdf_path.is_file():
        err(f"File not found: {pdf_path}")
        return 1

    prefix = pdf_path.stem
    log(f"Converting {pdf_path.name} at 300 DPI")
    try:
        images = convert_from_path(str(pdf_path), dpi=300)
    except Exception as e:
        err(f"{e}")
        return 1

    for idx, img in enumerate(images, start=1):
        out = f"{prefix}_page{idx}.jpg"
        img.save(out, "JPEG")
        ok(f"Saved {out}")
    return 0


if __name__ == "__main__":
    if len(sys.argv) != 2:
        err("Usage: yuleshow-pdf2jpg <input.pdf>")
        sys.exit(1)
    sys.exit(pdf_to_jpg(Path(sys.argv[1])))
#!/usr/bin/env python3
import sys
import os
from pdf2image import convert_from_path

def main():
    if len(sys.argv) != 2:
        print("Usage: yuleshow-pdf2jpg yourfile.pdf")
        sys.exit(1)

    pdf_path = sys.argv[1]

    if not os.path.isfile(pdf_path):
        print(f"Error: File not found: {pdf_path}")
        sys.exit(1)

    output_prefix = os.path.splitext(os.path.basename(pdf_path))[0]

    try:
        images = convert_from_path(pdf_path, dpi=300)
        for idx, img in enumerate(images):
            out_filename = f"{output_prefix}_page{idx+1}.jpg"
            img.save(out_filename, "JPEG")
            print(f"Saved {out_filename}")
    except Exception as e:
        print(f"Error: {e}")
        sys.exit(1)

if __name__ == "__main__":
    main()
