#!/usr/bin/env python3
"""yuleshow-rename-lunar-folder: append lunar/festival info to YYYYMMDD folders.

Usage: yuleshow-rename-lunar-folder
Scans CWD recursively. For each directory starting with 8 digits (YYYYMMDD),
appends " | <weekday> <ganzhi>年 <lunar month/day> [festivals/solar terms/US holidays]".
"""

import os
import re
import sys
from datetime import datetime, timedelta

try:
    from lunarcalendar import Converter, Solar
except ImportError:
    print("❌ Missing dep. Run: pip install lunarcalendar", file=sys.stderr)
    sys.exit(1)


def log(msg):  print(f"🚀 {msg}")
def ok(msg):   print(f"✅ {msg}")
def err(msg):  print(f"❌ {msg}", file=sys.stderr)


# --- US holidays (fixed + floating) ---
def get_us_holiday(dt: datetime):
    month, day, weekday = dt.month, dt.day, dt.weekday()
    nth = (day - 1) // 7 + 1

    fixed = {
        (1, 1): "New Year's Day", (2, 14): "Valentine's Day", (3, 17): "St. Patrick's Day",
        (7, 4): "Independence Day", (10, 31): "Halloween", (11, 11): "Veterans Day",
        (12, 24): "Christmas Eve", (12, 25): "Christmas Day",
    }

    if month == 1 and weekday == 0 and nth == 3: return "Martin Luther King Jr. Day"
    if month == 2 and weekday == 0 and nth == 3: return "Presidents' Day"
    if month == 5 and weekday == 0 and (dt + timedelta(days=7)).month == 6: return "Memorial Day"
    if month == 6 and day == 19: return "Juneteenth"
    if month == 9 and weekday == 0 and nth == 1: return "Labor Day"
    if month == 10 and weekday == 0 and nth == 2: return "Columbus Day"
    if month == 11 and weekday == 3 and nth == 4: return "Thanksgiving"
    return fixed.get((month, day))


# --- 24 solar terms (approximate gregorian dates) ---
def get_solar_term(dt: datetime):
    terms = {
        1: (5, "小寒", 20, "大寒"),  2: (4, "立春", 19, "雨水"),
        3: (5, "驚蟄", 20, "春分"),  4: (4, "清明", 20, "穀雨"),
        5: (5, "立夏", 21, "小滿"),  6: (5, "芒種", 21, "夏至"),
        7: (7, "小暑", 22, "大暑"),  8: (7, "立秋", 23, "處暑"),
        9: (7, "白露", 22, "秋分"), 10: (8, "寒露", 23, "霜降"),
        11: (7, "立冬", 22, "小雪"), 12: (7, "大雪", 21, "冬至"),
    }
    t = terms.get(dt.month)
    if not t:
        return None
    if dt.day == t[0]: return t[1]
    if dt.day == t[2]: return t[3]
    return None


def get_lunar_info(date_str: str):
    try:
        dt = datetime.strptime(date_str, "%Y%m%d")
    except ValueError:
        return None

    solar = Solar(dt.year, dt.month, dt.day)
    lunar = Converter.Solar2Lunar(solar)

    weekdays = ["星期一", "星期二", "星期三", "星期四", "星期五", "星期六", "星期日"]
    months_cn = ["正月", "二月", "三月", "四月", "五月", "六月",
                 "七月", "八月", "九月", "十月", "冬月", "臘月"]
    days_cn = ["初一", "初二", "初三", "初四", "初五", "初六", "初七", "初八", "初九", "初十",
               "十一", "十二", "十三", "十四", "十五", "十六", "十七", "十八", "十九", "二十",
               "廿一", "廿二", "廿三", "廿四", "廿五", "廿六", "廿七", "廿八", "廿九", "三十"]

    l_month, l_day = lunar.month, lunar.day
    is_leap = getattr(lunar, "isleap", False)
    events = []

    # 1. Wu-region lunar festivals
    festivals = {
        (1, 1): "春節",   (1, 15): "元宵節", (2, 2): "龍抬頭",   (2, 19): "觀音誕",
        (4, 8): "佛誕",   (5, 5): "端午節",   (6, 19): "觀音成道", (7, 7): "七夕",
        (7, 15): "中元節", (8, 15): "中秋節", (9, 9): "重陽節",   (9, 19): "觀音出家",
        (12, 8): "臘八節", (12, 24): "小年(廿四夜)"
    }
    if not is_leap and (l_month, l_day) in festivals:
        events.append(festivals[(l_month, l_day)])

    # 2. Lunar new year eve / small eve (dynamic)
    if not is_leap and l_month == 12:
        tomorrow = dt + timedelta(days=1)
        t_l = Converter.Solar2Lunar(Solar(tomorrow.year, tomorrow.month, tomorrow.day))
        if t_l.month == 1:
            events.append("大年夜")
        else:
            after = dt + timedelta(days=2)
            a_l = Converter.Solar2Lunar(Solar(after.year, after.month, after.day))
            if a_l.month == 1:
                events.append("小年夜")

    # 3. Solar terms + US holidays
    term = get_solar_term(dt)
    if term: events.append(term)
    us = get_us_holiday(dt)
    if us: events.append(us)

    # 4. Ganzhi year
    gan, zhi = "甲乙丙丁戊己庚辛壬癸", "子丑寅卯辰巳午未申酉戌亥"
    ganzhi = f"{gan[(lunar.year-4)%10]}{zhi[(lunar.year-4)%12]}"

    events_str = f" {' '.join(events)}" if events else ""
    return (f"{weekdays[dt.weekday()]} {ganzhi}年 "
            f"{'閏' if is_leap else ''}{months_cn[l_month-1]}{days_cn[l_day-1]}{events_str}")


def main() -> int:
    cwd = os.getcwd()
    log(f"Scanning folders under: {cwd}")
    pattern = re.compile(r"^(\d{8})")

    for root, dirs, _files in os.walk(cwd, topdown=False):
        for dirname in dirs:
            m = pattern.match(dirname)
            if not m:
                continue
            info = get_lunar_info(m.group(1))
            if not info:
                continue
            suffix = f" | {info}"
            if suffix in dirname:
                continue
            new_name = f"{dirname}{suffix}"
            try:
                os.rename(os.path.join(root, dirname), os.path.join(root, new_name))
                ok(f"{dirname} -> {new_name}")
            except Exception as e:
                err(f"{dirname}: {e}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
